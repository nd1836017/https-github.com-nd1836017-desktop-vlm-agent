# Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_api_key_here

# Optional overrides
GEMINI_MODEL=gemini-3.1-flash-lite-preview
TASKS_FILE=tasks.txt
ANIMATION_BUFFER_SECONDS=1.5

# Max retries on unparseable VLM response (per step attempt).
MAX_STEP_RETRIES=1

# Max replans after verifier FAIL (before halting). Higher = more resilient
# but uses more API quota per stuck step.
MAX_REPLANS_PER_STEP=2

# Rolling memory size: number of recent (step, action, verdict) records fed
# back into each plan prompt. Set to 0 to disable short-term memory.
HISTORY_WINDOW=5

# Checkpoint file for --resume. Written atomically after each verified step.
STATE_FILE=.agent_state.json

LOG_LEVEL=INFO
