# Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_api_key_here

# Optional overrides
GEMINI_MODEL=gemini-3.1-flash-lite-preview
TASKS_FILE=tasks.txt
ANIMATION_BUFFER_SECONDS=1.5

# Max retries on unparseable VLM response (per step attempt).
MAX_STEP_RETRIES=1

# Max replans after verifier FAIL (before halting). Higher = more resilient
# but uses more API quota per stuck step.
MAX_REPLANS_PER_STEP=2

# Rolling memory size: number of recent (step, action, verdict) records fed
# back into each plan prompt. Set to 0 to disable short-term memory.
HISTORY_WINDOW=5

# Checkpoint file for --resume. Written atomically after each verified step.
STATE_FILE=.agent_state.json

# Two-stage CLICK: after the planner returns a coarse CLICK [x,y], crop a
# TWO_STAGE_CROP_SIZE_PX x TWO_STAGE_CROP_SIZE_PX region around the point and
# ask the VLM to list refined targets. If >1 is returned, a disambiguation
# call picks the one matching the step. Adds ~1 API call per CLICK on happy
# paths, +2 when disambiguation fires. Set to false to use the legacy
# single-call coarse click.
ENABLE_TWO_STAGE_CLICK=true
TWO_STAGE_CROP_SIZE_PX=300
MAX_CLICK_CANDIDATES=5

# Human-like click delay (bot-detection dodge). Before every CLICK the agent
# sleeps a random interval in [CLICK_MIN_DELAY_SECONDS, CLICK_MAX_DELAY_SECONDS]
# on top of the post-click animation buffer. Setting both to 0 disables.
CLICK_MIN_DELAY_SECONDS=0.8
CLICK_MAX_DELAY_SECONDS=2.0

# Per-keystroke jitter for TYPE. Each character is typed then the agent sleeps
# a random interval in [TYPE_MIN_INTERVAL_SECONDS, TYPE_MAX_INTERVAL_SECONDS]
# so typing cadence isn't perfectly uniform. Setting both to 0 disables.
TYPE_MIN_INTERVAL_SECONDS=0.03
TYPE_MAX_INTERVAL_SECONDS=0.12

# Retry-with-backoff on transient Gemini errors (429 / 5xx). Exponential with
# full jitter, capped by MAX_DELAY. The agent NEVER falls back to a different
# model — it waits and retries on the pinned GEMINI_MODEL.
GEMINI_RETRY_MAX_ATTEMPTS=6
GEMINI_RETRY_BASE_DELAY_SECONDS=5.0
GEMINI_RETRY_MAX_DELAY_SECONDS=300.0

# When true (default), TYPE commands are logged as `TYPE <REDACTED, N chars>`
# instead of printing the literal text. Keeps passwords and other secrets out
# of the local log file. Set to false for debugging if you really need the
# literal characters in the log.
LOG_REDACT_TYPE=true

# Ask Gemini for a JSON-schema response (deterministic parse). When false,
# the planner/verifier use plain-text output and the regex parser — the
# behavior prior to PR #6.
ENABLE_JSON_OUTPUT=true

# Global cap on replans across the WHOLE run (not per-step). When the agent
# has issued this many replans cumulatively, it halts with a clear reason
# instead of silently thrashing. Set to 0 to disable.
MAX_TOTAL_REPLANS=10

# Per-step run artifacts for postmortems. When true, each run gets its own
# `RUN_ARTIFACTS_DIR/<timestamp>/` directory containing pre/post screenshots,
# raw plan responses, verdicts, and a rolling summary.json. Off by default —
# can fill disk on long runs. Useful for debugging flaky steps.
SAVE_RUN_ARTIFACTS=false
RUN_ARTIFACTS_DIR=runs

# RPD (Requests-Per-Day) guard. Tracks outbound Gemini calls this run and
# triggers safety thresholds against your daily quota. RPD_LIMIT=0 disables
# both warnings and halt. Defaults match `gemini-3.1-flash-lite-preview`'s
# free-tier limit of 500 requests/day.
#   At WARN threshold (default 75%): a loud WARNING is logged.
#   At HALT threshold (default 95%): the agent stops cleanly between steps
#     with the checkpoint intact, so `--resume` picks up later.
RPD_LIMIT=500
RPD_WARN_THRESHOLD=0.75
RPD_HALT_THRESHOLD=0.95

# File-handling mode for DOWNLOAD / ATTACH_FILE / CAPTURE_FOR_AI primitives.
# Only consulted when the tasks file actually uses one of those primitives —
# tasks that don't touch files never trigger any prompt or workspace setup.
# - temp: files saved to an OS temp dir, wiped on success / kept on failure
# - save: files persisted to WORKDIR (or ./agent_files if unset)
# - feed: files never written to disk; bytes streamed straight to the VLM
# Leave blank to ask interactively when the tasks file uses file primitives.
# FILE_MODE=temp
# WORKDIR=./agent_files

# Tier 4 reliability: per-step wall-clock timeout and stuck-step detection.
# STEP_TIMEOUT_SECONDS bounds the total wall time spent on any one step
# (including replans + parse retries). When exceeded, the agent fails the
# step and continues / halts per the usual policy. Set to 0 to disable.
# STUCK_STEP_THRESHOLD is the number of consecutive identical-screenshot
# attempts that triggers an early FAIL — saves replan budget when the UI
# is unresponsive (e.g. modal stuck behind another window). Set to 0 to
# disable.
STEP_TIMEOUT_SECONDS=180.0
STUCK_STEP_THRESHOLD=3

# Smart-screenshot (PR S Phase 1): trim every screenshot before sending
# it to Gemini. The defaults are well above what Gemini's vision tokenizer
# would otherwise discard, so they don't change accuracy — they just stop
# wasting bytes on pixels and PNG-overhead the model would throw away.
#
# VLM_IMAGE_MAX_DIM caps the longer edge in pixels (1280 is a good
# default for desktop UI; raise to 1920 if you really need full
# resolution, set to 0 to disable downsampling entirely).
# VLM_IMAGE_QUALITY is the JPEG quality (1-100). 80 is the sweet spot —
# button text stays sharp, ~1/20 the size of an equivalent PNG.
VLM_IMAGE_MAX_DIM=1280
VLM_IMAGE_QUALITY=80

# Layer 2 (opt-in): drop the screenshot from plan_action calls when the
# current frame fingerprints identically to the previous one — i.e. the
# last action did nothing visible. Saves an entire vision pass on stuck
# steps. Off by default; turn on with VLM_SKIP_IDENTICAL_FRAMES=true if
# you want to A/B it on your tasks. Verify/disambiguate/refine always
# get fresh images regardless.
VLM_SKIP_IDENTICAL_FRAMES=false

# Browser fast-path: when true and Chrome is reachable on the CDP debug
# port, the planner can emit BROWSER_GO / BROWSER_CLICK / BROWSER_FILL
# primitives that drive the active tab via JSON-RPC instead of going
# through the VLM-vision pipeline. Saves ~3 expensive steps per
# "navigate to URL" and ~1 per known form field.
#
# Setup: launch Chrome with --remote-debugging-port=29229 (the bundled
# scripts/launch-chrome.sh and scripts/launch-chrome.bat do this for you).
# Verify with: curl http://localhost:29229/json/version
#
# Failure mode: if CDP isn't reachable when the agent starts, browser
# commands synthesize a clear FAIL and the planner falls back to visual
# CLICK / TYPE on the next attempt. Off by default until tested.
BROWSER_FAST_PATH=false
BROWSER_CDP_HOST=localhost
BROWSER_CDP_PORT=29229

# Smart task router: one Gemini call at run start decomposes raw
# tasks-file lines into atomic steps and tags each as
# ``browser-fast`` (CDP-driven; zero vision tokens), ``browser-vlm``
# (browser action that needs vision), or ``desktop-vlm`` (native
# apps, OS dialogs). The planner sees the tag + a suggested literal
# command (e.g. ``BROWSER_GO [https://youtube.com]``) as advisory
# context; if the screen disagrees it overrides the hint.
#
# Three modes:
#   auto    (default) — call Gemini once at run start. On error,
#                       fall through to no-routing behavior (safe).
#   manual           — skip Gemini; only honor inline ``[tag]``
#                       prefixes you write yourself in tasks.txt
#                       (e.g. ``[browser-fast] open youtube``,
#                       ``[vlm] post on instagram``).
#   off              — no router at all; behavior identical to
#                       pre-router builds. Use as a safety rollback.
TASK_ROUTING=auto

# Task decomposition (TASK_DECOMPOSITION). One Gemini call at run start
# that splits compound natural-language steps ("play the 2nd video on
# youtube") into atomic substeps the planner can verify one at a time.
# Runs BEFORE the router, so the router classifies the post-decomposition
# atomic steps. Two values:
#   auto             — runs Gemini; gracefully falls back to the
#                       original step list on error (safe).
#   off              — no decomposition. Use if the decomposer mangles
#                       a particular task; you can split steps yourself.
TASK_DECOMPOSITION=auto

# Skill library (SKILLS_DIR). Folder of reusable ``.txt`` snippets that
# any tasks file can pull in via ``USE <skill_name>``. Skills can use
# every primitive (REMEMBER, FOR_EACH_ROW, IF/ELSE, BROWSER_*) and can
# call other skills. Cycle detection + max recursion depth keep things
# safe. Leave commented to default to ``./skills/`` if that folder
# exists; uncomment to point elsewhere.
#   python -m agent --list-skills              # show every skill
#   python -m agent --new-skill open_chrome    # scaffold a new skill
# SKILLS_DIR=./skills

# Conditional logic (IF / WAIT_UNTIL). The agent re-evaluates these via
# a single VLM screenshot check; WAIT_UNTIL polls until the condition
# is true or the budget is exhausted. The IF directive uses a single
# screenshot — no polling, no retry.
WAIT_UNTIL_TIMEOUT_SECONDS=30.0
WAIT_UNTIL_POLL_SECONDS=2.0

LOG_LEVEL=INFO
